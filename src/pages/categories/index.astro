---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

// Define category information
const categoryInfo = {
  classic: {
    name: 'Classic Cupcakes',
    description: 'Timeless recipes that have been perfected over generations. These are the cupcakes that bring back childhood memories and create new ones.',
    color: 'from-cupcake-coral to-sunshine-400',
    icon: '🧁'
  },
  keto: {
    name: 'Keto Cupcakes',
    description: 'Low-carb, high-fat cupcakes that dont compromise on taste. Perfect for maintaining your ketogenic lifestyle while satisfying your sweet tooth.',
    color: 'from-emerald-500 to-teal-600',
    icon: '🥑'
  },
  vegan: {
    name: 'Vegan Cupcakes',
    description: 'Plant-based cupcakes that are kind to animals and the environment. Proving that vegan baking can be just as delicious and indulgent.',
    color: 'from-emerald-500 to-teal-600',
    icon: '🌱'
  },
  'nut-free': {
    name: 'Nut-Free Cupcakes',
    description: 'Safe and delicious cupcakes for those with nut allergies. Every recipe is carefully crafted to avoid cross-contamination while maximizing flavor.',
    color: 'from-amber-400 to-orange-500',
    icon: '🚫'
  },
  'gluten-free': {
    name: 'Gluten-Free Cupcakes',
    description: 'Cupcakes made without gluten but full of flavor and texture. Perfect for those with celiac disease or gluten sensitivity.',
    color: 'from-purple-500 to-violet-600',
    icon: '🌾'
  },
  gourmet: {
    name: 'Gourmet Cupcakes',
    description: 'Elegant, elevated flavors and techniques for a true wow-factor presentation.',
    color: 'from-rose-500 to-pink-600',
    icon: '🍒'
  },
  tropical: {
    name: 'Tropical Cupcakes',
    description: 'Sun-kissed flavors: mango, coconut, pineapple, and holiday vibes in every bite.',
    color: 'from-sunshine-400 to-amber-500',
    icon: '🌴'
  },
  spiced: {
    name: 'Spiced Cupcakes',
    description: 'Warm spices with character: cinnamon, chili, cardamom, and more for cozy depth.',
    color: 'from-orange-600 to-red-600',
    icon: '🌶️'
  },
  seasonal: {
    name: 'Seasonal Cupcakes',
    description: 'Flavors inspired by the season: fresh fruit, pastels and festive looks.',
    color: 'from-cupcake-pink to-rose-500',
    icon: '🌸'
  }
};

const schemaData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Cupcake Categories",
  "description": "Explore our cupcake categories",
  "url": "https://incr-ediblecupcakes.com/categories",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": Object.entries(categoryInfo).map(([id, info], index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "name": info.name,
      "description": info.description,
      "url": `https://incr-ediblecupcakes.com/categories/${id}`
    }))
  }
};
---

<BaseLayout
  title="Cupcake Categories - Incr-EdibleCupCakes"
  description="Explore our cupcake categories including Classic, Keto, Vegan, Nut-Free, and Gluten-Free options. Find the perfect recipe for your dietary needs."
  canonical="https://incr-ediblecupcakes.com/categories"
>
  <Fragment slot="head">
    <meta name="keywords" content="cupcake categories, classic cupcakes, keto cupcakes, vegan cupcakes, nut-free cupcakes, gluten-free cupcakes, dietary cupcakes" />
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  </Fragment>
  <Header />
  <main id="main-content" class="pt-16 lg:pt-20 pb-20">
    <div class="max-w-6xl mx-auto px-4">
      <Breadcrumbs items={[
        { name: 'Home', url: '/' },
        { name: 'Categories' }
      ]} />
    </div>

    <section class="py-14 bg-gradient-to-br from-rose-50 to-pink-50 border-b border-rose-100/50">
      <div class="max-w-6xl mx-auto px-4">
        <h1 class="text-4xl md:text-5xl font-bold mb-4 text-gray-900">
          Cupcake Categories
        </h1>
        <p class="text-lg text-gray-600 max-w-3xl">
          Nine curated collections ,  from classic buttercream to keto, vegan, and nut-free ,  each with tested recipes,
          ingredient notes, and FAQs. Pick a category that matches your pantry and dietary needs, then open a recipe
          with full timings, nutrition estimates, and substitution links.
        </p>
      </div>
    </section>

    {/* Category Grid */}
    <section class="py-14">
      <div class="max-w-6xl mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {Object.entries(categoryInfo).map(([id, info]) => (
            <a
              href={`/categories/${id}`}
              class={`group relative overflow-hidden bg-gradient-to-br ${info.color} p-8 rounded-2xl text-white shadow-lg transition-all duration-300 hover:shadow-xl hover:-translate-y-0.5`}
            >
              <div class="absolute inset-0 bg-white/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
              <div class="relative">
                <div class="text-4xl mb-5 drop-shadow">{info.icon}</div>
                <h2 class="text-2xl font-extrabold mb-2 tracking-tight">{info.name}</h2>
                <p class="opacity-95 leading-relaxed">{info.description}</p>
                <div class="mt-6 inline-flex items-center gap-2 text-white/95 bg-white/10 backdrop-blur px-4 py-2 rounded-full border border-white/20 group-hover:bg-white/15">
                  <span class="text-sm font-semibold">View {info.name}</span>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
