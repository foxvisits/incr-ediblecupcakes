---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import RecipeCard from '../../components/RecipeCard.tsx';
import { validatedRecipes as recipes } from '../../data/recipes';
import { categoryExtraContent } from '../../data/categoryContent';
import { SITE_IMAGES } from '../../data/siteAssets';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const categoryInfo: Record<string, { name: string; description: string; color: string; icon: string }> = {
  classic: { name: 'Classic Cupcakes', description: 'Timeless recipes perfected for home bakers.', color: 'from-blue-500 to-indigo-600', icon: '🧁' },
  keto: { name: 'Keto Cupcakes', description: 'Low-carb cupcakes that do not compromise on taste.', color: 'from-green-500 to-emerald-600', icon: '🥑' },
  vegan: { name: 'Vegan Cupcakes', description: 'Plant-based cupcakes that are kind and indulgent.', color: 'from-emerald-500 to-teal-600', icon: '🌱' },
  'nut-free': { name: 'Nut-Free Cupcakes', description: 'Safe, flavorful cupcakes for nut allergies.', color: 'from-amber-500 to-orange-600', icon: '🚫' },
  'gluten-free': { name: 'Gluten-Free Cupcakes', description: 'Full flavor without gluten.', color: 'from-purple-500 to-violet-600', icon: '🌾' },
  gourmet: { name: 'Gourmet Cupcakes', description: 'Elevated flavors and presentation.', color: 'from-pink-600 to-rose-600', icon: '🍒' },
  tropical: { name: 'Tropical Cupcakes', description: 'Mango, coconut, and sun-kissed flavors.', color: 'from-amber-500 to-yellow-500', icon: '🌴' },
  spiced: { name: 'Spiced Cupcakes', description: 'Warm spices and bold character.', color: 'from-orange-600 to-red-600', icon: '🌶️' },
  seasonal: { name: 'Seasonal Cupcakes', description: 'Flavors inspired by the season.', color: 'from-rose-500 to-pink-600', icon: '🌸' },
};

export function getStaticPaths() {
  return Object.keys(categoryExtraContent).map((categoryId) => ({
    params: { categoryId },
  }));
}

const { categoryId } = Astro.params;
const currentCategory = categoryId ? categoryInfo[categoryId] : null;
const categoryRecipes = categoryId ? recipes.filter((recipe) => recipe.category === categoryId) : [];
const extra = categoryId ? categoryExtraContent[categoryId] : null;
const categoryOgImage = categoryRecipes.length > 0 ? categoryRecipes[0].image : SITE_IMAGES.hero;

const schemaData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: currentCategory?.name ?? 'Cupcake Categories',
  description: extra?.intro ?? currentCategory?.description,
  url: `https://incr-ediblecupcakes.com/categories/${categoryId}`,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: categoryRecipes.length,
    itemListElement: categoryRecipes.map((recipe, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: recipe.title,
      url: `https://incr-ediblecupcakes.com/recipe/${recipe.slug}`,
    })),
  },
};

const faqSchema = extra?.faq?.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: extra.faq.map((f) => ({
        '@type': 'Question',
        name: f.question,
        acceptedAnswer: { '@type': 'Answer', text: f.answer },
      })),
    }
  : null;
---

<BaseLayout
  title={`${currentCategory?.name} | Incr-EdibleCupCakes`}
  description={extra?.intro?.slice(0, 155) ?? currentCategory?.description}
  image={categoryOgImage}
  canonical={`https://incr-ediblecupcakes.com/categories/${categoryId}`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  </Fragment>
  <Header />
  <main id="main-content" class="pt-16 lg:pt-20 pb-20">
    <div class="max-w-6xl mx-auto px-4">
      <Breadcrumbs items={[
        { name: 'Home', url: '/' },
        { name: 'Categories', url: '/categories' },
        { name: currentCategory?.name || 'Category' },
      ]} />
    </div>

    <div class={`bg-gradient-to-r ${currentCategory?.color} p-8 md:p-12 rounded-lg text-white mb-8 max-w-6xl mx-auto`}>
      <a href="/categories" class="inline-flex items-center text-white hover:text-white/80 mb-4">
        ← Back to Categories
      </a>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">{currentCategory?.icon} {currentCategory?.name}</h1>
      <p class="text-lg md:text-xl opacity-90 max-w-3xl">{currentCategory?.description}</p>
    </div>

    <article class="max-w-6xl mx-auto px-4 mb-10 prose prose-lg max-w-none">
      {extra && <p class="text-gray-700 leading-relaxed">{extra.intro}</p>}
      {categoryId === 'keto' && categoryRecipes.length > 0 && (
        <div class="overflow-x-auto mt-6 not-prose">
          <table class="w-full text-sm text-left border border-gray-200 rounded-lg">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-2 font-semibold">Recipe</th>
                <th class="px-4 py-2 font-semibold">Difficulty</th>
                <th class="px-4 py-2 font-semibold">Prep</th>
              </tr>
            </thead>
            <tbody>
              {categoryRecipes.map((r) => (
                <tr class="border-t border-gray-100">
                  <td class="px-4 py-2"><a href={`/recipe/${r.slug}`} class="text-rose-600 hover:underline">{r.title}</a></td>
                  <td class="px-4 py-2">{r.difficulty}</td>
                  <td class="px-4 py-2">{r.prepTime}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
      {categoryId === 'nut-free' && (
        <p class="mt-4 text-sm text-amber-800 bg-amber-50 border border-amber-100 rounded-lg px-4 py-3">
          See also: <a href="/guides/egg-substitutes-for-cupcakes" class="text-rose-600 hover:underline">egg substitutes guide</a> and
          <a href="/substitutes/egg" class="text-rose-600 hover:underline ml-1">egg swap cheatsheet</a>.
        </p>
      )}
    </article>

    {extra?.faq && extra.faq.length > 0 && (
      <section class="max-w-6xl mx-auto px-4 mb-10">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Common questions</h2>
        <div class="space-y-4">
          {extra.faq.map((f) => (
            <details class="bg-white border border-gray-200 rounded-xl p-4">
              <summary class="font-semibold text-gray-900 cursor-pointer">{f.question}</summary>
              <p class="mt-2 text-gray-700 text-sm">{f.answer}</p>
            </details>
          ))}
        </div>
      </section>
    )}

    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">{categoryRecipes.length} recipes</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {categoryRecipes.map((recipe) => (
          <RecipeCard recipe={recipe} client:load />
        ))}
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
