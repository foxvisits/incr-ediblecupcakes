---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import RecipeCard from '../../components/RecipeCard.tsx';
import { validatedRecipes as recipes } from '../../data/recipes';
import OGImageGenerator from '../../components/OGImageGenerator.astro';

export async function getStaticPaths() {
  const allTags = Array.from(
    new Set(
      recipes.flatMap((r) => (r.tags ? r.tags.map((t) => t.toLowerCase()) : []))
    )
  );
  return allTags.map((tag) => ({ params: { tag }, props: { tag } }));
}

const { tag } = Astro.params;
const normalized = (tag || '').toLowerCase();
const taggedRecipes = recipes.filter((r) => r.tags?.map((t) => t.toLowerCase()).includes(normalized));

const schemaData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `Cupcake recipes with tag: ${tag}`,
  description: `Browse cupcake recipes tagged with ${tag}.` ,
  url: `https://incr-ediblecupcakes.com/tags/${tag}`,
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: taggedRecipes.length,
    itemListElement: taggedRecipes.map((recipe, index) => ({
      "@type": "Recipe",
      position: index + 1,
      name: recipe.title,
      url: `https://incr-ediblecupcakes.com/recipe/${recipe.slug}`,
      image: `https://incr-ediblecupcakes.com${recipe.image}`,
      description: recipe.shortDescription,
      keywords: recipe.tags?.join(', ')
    }))
  }
};
---

<BaseLayout
  title={`Recipes tagged "${tag}" - Incr-EdibleCupCakes`}
  description={`Explore cupcake recipes tagged with ${tag}.`}
  canonical={`https://incr-ediblecupcakes.com/tags/${tag}`}
>
  <Header />
  <main class="pt-16 lg:pt-20">
    <Fragment slot="head">
      <meta name="keywords" content={`cupcake recipes, ${tag} cupcakes, baking, tags`} />
      <meta property="og:title" content={`Recipes tagged ${tag} | Incr-EdibleCupCakes`} />
      <meta property="og:description" content={`Explore cupcake recipes tagged with ${tag}.`} />
      <meta property="og:type" content="website" />
      <meta property="og:url" content={`https://incr-ediblecupcakes.com/tags/${tag}`} />
      <meta name="twitter:card" content="summary_large_image" />
      <meta name="twitter:title" content={`Recipes tagged ${tag} | Incr-EdibleCupCakes`} />
      <meta name="twitter:description" content={`Explore cupcake recipes tagged with ${tag}.`} />
      <OGImageGenerator title={`Recipes tagged ${tag}`} description={`Explore cupcake recipes tagged with ${tag}.`} />
      <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
    </Fragment>

    <div class="max-w-6xl mx-auto px-4">
      <div class="bg-gradient-to-r from-rose-500 to-pink-600 p-8 rounded-lg text-white mb-8">
        <a href="/tags" class="inline-flex items-center text-white hover:text-white/80 mb-4">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          Back to Tags
        </a>
        <h1 class="text-4xl md:text-5xl font-bold mb-2">#{tag}</h1>
        <p class="text-lg opacity-90">Recipes matching the "{tag}" tag.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {taggedRecipes.map((recipe) => (
          <RecipeCard recipe={recipe} />
        ))}
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>


