---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import RecipeCard from '../../components/RecipeCard.tsx';
import { validatedRecipes as recipes } from '../../data/recipes';
import {
  getTagIntro,
  getTagFaq,
  isCategoryDuplicateTag,
} from '../../data/tagContent';

export async function getStaticPaths() {
  const allTags = Array.from(
    new Set(recipes.flatMap((r) => (r.tags ? r.tags.map((t) => t.toLowerCase()) : [])))
  );
  return allTags.map((tag) => ({ params: { tag }, props: { tag } }));
}

const { tag } = Astro.params;
const normalized = (tag || '').toLowerCase();
const taggedRecipes = recipes.filter((r) =>
  r.tags?.map((t) => t.toLowerCase()).includes(normalized)
);
const thinTag = taggedRecipes.length < 2;
const tagIntro = getTagIntro(normalized, taggedRecipes.length);
const tagFaq = getTagFaq(normalized);
const isCategoryDup = isCategoryDuplicateTag(normalized);

const faqSchema =
  tagFaq.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: tagFaq.map((f) => ({
          '@type': 'Question',
          name: f.question,
          acceptedAnswer: { '@type': 'Answer', text: f.answer },
        })),
      }
    : null;

const schemaData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `Cupcake recipes tagged: ${tag}`,
  description: tagIntro,
  url: `https://incr-ediblecupcakes.com/tags/${tag}`,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: taggedRecipes.length,
    itemListElement: taggedRecipes.map((recipe, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: recipe.title,
      url: `https://incr-ediblecupcakes.com/recipe/${recipe.slug}`,
    })),
  },
};
---

<BaseLayout
  title={`${tag} Cupcake Recipes | Incr-EdibleCupCakes`}
  description={tagIntro.slice(0, 155)}
  canonical={`https://incr-ediblecupcakes.com/tags/${tag}`}
  robots={thinTag || isCategoryDup ? 'noindex, follow' : undefined}
>
  <Fragment slot="head">
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  </Fragment>
  <Header />
  <main id="main-content" class="pt-16 lg:pt-20 pb-20">
    <div class="max-w-6xl mx-auto px-4">
      <div class="bg-gradient-to-r from-rose-500 to-pink-600 p-8 rounded-lg text-white mb-8">
        <a href="/tags" class="inline-flex items-center text-white hover:text-white/80 mb-4">
          ← Back to Tags
        </a>
        <h1 class="text-4xl md:text-5xl font-bold mb-3">#{tag}</h1>
        <p class="text-lg opacity-95 max-w-3xl leading-relaxed">{tagIntro}</p>
        {isCategoryDup && (
          <p class="mt-4 text-sm bg-white/15 rounded-lg px-4 py-2 inline-block">
            Browse the full
            <a href={`/categories/${normalized}`} class="underline font-semibold ml-1 mr-1">
              {tag} category
            </a>
            for dietary overview and FAQ.
          </p>
        )}
      </div>

      {tagFaq.length > 0 && (
        <section class="mb-10 max-w-3xl">
          <h2 class="text-xl font-bold text-gray-900 mb-3">About this tag</h2>
          <div class="space-y-2">
            {tagFaq.map((f) => (
              <details class="bg-white border border-gray-200 rounded-xl p-4">
                <summary class="font-semibold text-gray-900 cursor-pointer">{f.question}</summary>
                <p class="mt-2 text-gray-700 text-sm">{f.answer}</p>
              </details>
            ))}
          </div>
        </section>
      )}

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {taggedRecipes.map((recipe) => (
          <RecipeCard recipe={recipe} />
        ))}
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
