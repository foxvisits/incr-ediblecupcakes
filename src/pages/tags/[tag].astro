---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import RecipeCard from '../../components/RecipeCard.tsx';
import { validatedRecipes as recipes } from '../../data/recipes';
export async function getStaticPaths() {
  const allTags = Array.from(
    new Set(
      recipes.flatMap((r) => (r.tags ? r.tags.map((t) => t.toLowerCase()) : []))
    )
  );
  return allTags.map((tag) => ({ params: { tag }, props: { tag } }));
}

const { tag } = Astro.params;
const normalized = (tag || '').toLowerCase();
const taggedRecipes = recipes.filter((r) => r.tags?.map((t) => t.toLowerCase()).includes(normalized));
const thinTag = taggedRecipes.length < 2;
const tagIntro = taggedRecipes.length === 0
  ? `No recipes are currently tagged with "${tag}". Browse the full collection or try another tag.`
  : `Recipes tagged "${tag}" share this flavor or technique focus. ${taggedRecipes.length} recipe${taggedRecipes.length === 1 ? '' : 's'} below include ingredients, bake times, and troubleshooting tips.`;

const schemaData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `Cupcake recipes with tag: ${tag}`,
  description: tagIntro,
  url: `https://incr-ediblecupcakes.com/tags/${tag}`,
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: taggedRecipes.length,
    itemListElement: taggedRecipes.map((recipe, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: recipe.title,
      url: `https://incr-ediblecupcakes.com/recipe/${recipe.slug}`,
    }))
  }
};
---

<BaseLayout
  title={`${tag} Cupcake Recipes | Incr-EdibleCupCakes`}
  description={tagIntro.slice(0, 155)}
  canonical={`https://incr-ediblecupcakes.com/tags/${tag}`}
  robots={thinTag ? 'noindex, follow' : undefined}
>
  <Fragment slot="head">
    <meta name="keywords" content={`cupcake recipes, ${tag} cupcakes, baking, tags`} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  </Fragment>
  <Header />
  <main id="main-content" class="pt-16 lg:pt-20">
    <div class="max-w-6xl mx-auto px-4">
      <div class="bg-gradient-to-r from-rose-500 to-pink-600 p-8 rounded-lg text-white mb-8">
        <a href="/tags" class="inline-flex items-center text-white hover:text-white/80 mb-4">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          Back to Tags
        </a>
        <h1 class="text-4xl md:text-5xl font-bold mb-2">#{tag}</h1>
        <p class="text-lg opacity-90 max-w-2xl">{tagIntro}</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {taggedRecipes.map((recipe) => (
          <RecipeCard recipe={recipe} />
        ))}
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>


