---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { validatedRecipes as recipes } from '../../data/recipes';
import OGImageGenerator from '../../components/OGImageGenerator.astro';

const allTags = Array.from(
  new Set(
    recipes.flatMap((r) => (r.tags ? r.tags.map((t) => t.toLowerCase()) : []))
  )
).sort();

const schemaData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: 'Cupcake Tags',
  description: 'Browse cupcake recipe tags and discover related recipes',
  url: 'https://incr-ediblecupcakes.com/tags',
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: allTags.length,
    itemListElement: allTags.map((t, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: t,
      url: `https://incr-ediblecupcakes.com/tags/${t}`
    }))
  }
};
---

<BaseLayout
  title="Recipe Tags - Incr-EdibleCupCakes"
  description="Browse cupcake recipe tags and find your next bake."
  canonical="https://incr-ediblecupcakes.com/tags"
>
  <Header />
  <main id="main-content" class="pt-16 lg:pt-20">
    <Fragment slot="head">
      <meta name="keywords" content="cupcake tags, ingredients, flavors, baking" />
      <meta property="og:title" content="Recipe Tags | Incr-EdibleCupCakes" />
      <meta property="og:description" content="Browse cupcake recipe tags and find your next bake." />
      <meta property="og:type" content="website" />
      <meta property="og:url" content="https://incr-ediblecupcakes.com/tags" />
      <meta name="twitter:card" content="summary_large_image" />
      <meta name="twitter:title" content="Recipe Tags | Incr-EdibleCupCakes" />
      <meta name="twitter:description" content="Browse cupcake recipe tags and find your next bake." />
      <OGImageGenerator title="Recipe Tags" description="Browse cupcake recipe tags and find your next bake." />
      <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
    </Fragment>

    <div class="max-w-6xl mx-auto px-4">
      <h1 class="text-4xl md:text-5xl font-bold mb-6 text-gray-900">Recipe Tags</h1>
      <p class="text-lg text-gray-600 mb-10">Explore by flavors, ingredients and themes.</p>

      <div class="flex flex-wrap gap-3">
        {allTags.map((t) => (
          <a href={`/tags/${t}`} class="px-4 py-2 rounded-full bg-rose-50 text-rose-700 hover:bg-rose-100 transition">
            #{t}
          </a>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>


