---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ClientOnly from '../components/ClientOnly.tsx';

const schemaData = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Sarah",
  "jobTitle": "Home Baker & Recipe Developer",
  "description": "Recipe developer behind Incr-EdibleCupCakes, creating tested cupcake recipes for classic, keto, vegan, and allergen-friendly baking at home.",
  "url": "https://incr-ediblecupcakes.com/about",
  "image": "https://incr-ediblecupcakes.com/Sarah.png",
  "knowsAbout": [
    "Cupcake Baking",
    "Keto Baking",
    "Vegan Baking",
    "Allergen-Free Baking",
    "Recipe Development"
  ],
  "worksFor": {
    "@type": "Organization",
    "name": "Incr-EdibleCupCakes"
  }
};
---

<BaseLayout 
  title="About Sarah | Incr-EdibleCupCakes"
  description="Meet Sarah, home baker and recipe developer behind Incr-EdibleCupCakes. Tested cupcake recipes for keto, vegan, nut-free, and classic baking."
  image="/Sarah.png"
  canonical="https://incr-ediblecupcakes.com/about"
  ogType="profile"
>
  <Fragment slot="head">
    <meta name="keywords" content="Sarah baker, home baker, cupcake recipe developer, keto baking, vegan baking, allergen-free baking" />
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  </Fragment>
  <Header />
  
  <main id="main-content" class="pt-16 lg:pt-20">
    {/* Hero Section */}
    <section class="relative py-20 bg-gradient-to-br from-cupcake-coral via-sunshine-400 to-cupcake-cherry overflow-hidden">
      <div class="absolute inset-0 pointer-events-none">
        <ClientOnly client:load>
          <>
            {[...Array(12)].map((_, i) => (
              <div
                key={i}
                class="absolute animate-float-random opacity-20"
                style={{
                  left: `${Math.random() * 100}%`,
                  top: `${Math.random() * 100}%`,
                  animationDelay: `${i * 0.3}s`,
                  animationDuration: `${4 + i * 0.5}s`,
                }}
              >
                {i % 4 === 0 ? '🧁' : i % 4 === 1 ? '🍰' : i % 4 === 2 ? '🎂' : '🧁'}
              </div>
            ))}
          </>
        </ClientOnly>
      </div>
      
      <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="text-white">
            <h1 class="font-quicksand text-4xl sm:text-5xl font-black mb-6 leading-tight drop-shadow-2xl">
              Meet the Baker Behind the
              <span class="block text-sunshine-300 animate-gradient-text">Magic</span>
            </h1>
            <p class="font-nunito text-xl text-pink-100 leading-relaxed drop-shadow-lg">
              Hi, I'm Sarah. I develop and test every cupcake recipe on this site in my home kitchen, classic comfort bakes,
              keto-friendly options, vegan batters, and nut-free alternatives. My goal is clear instructions and honest results.
            </p>
          </div>
          
          <div class="relative">
            <div class="w-80 h-80 mx-auto relative">
              <div class="absolute inset-0 bg-gradient-to-br from-yellow-400 to-rose-400 rounded-full animate-pulse" />
              <img
                src="/Sarah.png"
                alt="Sarah - professional baker and recipe developer behind Incr-EdibleCupCakes"
                class="relative z-10 w-full h-full object-cover rounded-full border-4 border-white/20 shadow-2xl"
                loading="eager"
                width={320}
                height={320}
              />
              <div class="absolute -top-4 -right-4 w-16 h-16 bg-yellow-400 rounded-full flex items-center justify-center shadow-lg animate-bounce">
                <svg class="w-8 h-8 text-cupcake-coral" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                </svg>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Story Section */}
    <section class="py-20 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="font-quicksand text-4xl font-black text-gray-900 mb-6">
            My <span class="text-cupcake-coral">Journey</span>
          </h2>
        </div>

        <div class="space-y-12">
          <div class="flex flex-col md:flex-row items-center gap-8">
            <div class="md:w-1/2">
              <img
                src="/Where It All Began.jpg"
                alt="Baking in grandmother's kitchen - traditional place where Sarah learned to bake cupcakes"
                class="w-full h-64 object-cover rounded-2xl shadow-lg"
                loading="lazy"
                width={400}
                height={256}
              />
            </div>
            <div class="md:w-1/2">
              <h3 class="font-quicksand text-2xl font-bold text-gray-900 mb-4">Where It All Began</h3>
              <p class="font-nunito text-gray-600 leading-relaxed">
                My love for baking started at age 7 in my grandmother's cozy kitchen. She taught me that baking 
                isn't just about following recipes, it's about creating moments of joy and bringing people together. 
                Every Saturday morning, we'd experiment with new flavors and techniques, always pushing the boundaries 
                of traditional baking.
              </p>
            </div>
          </div>

          <div class="flex flex-col md:flex-row-reverse items-center gap-8">
            <div class="md:w-1/2">
              <img
                src="/Professional Training.jpg"
                alt="Sarah learning baking techniques through practice and recipe testing at home"
                class="w-full h-64 object-cover rounded-2xl shadow-lg"
                loading="lazy"
                width={400}
                height={256}
              />
            </div>
            <div class="md:w-1/2">
              <h3 class="font-quicksand text-2xl font-bold text-gray-900 mb-4">Learning & Testing</h3>
              <p class="font-nunito text-gray-600 leading-relaxed">
                I studied baking through practice, cookbooks, and community feedback, not a culinary school diploma.
                Over time I focused on dietary alternatives: keto sweeteners, egg replacers, and nut-free ingredients.
                Each recipe here is retested until the texture and flavor are repeatable in a standard home oven.
              </p>
            </div>
          </div>

          <div class="flex flex-col md:flex-row items-center gap-8">
            <div class="md:w-1/2">
              <img
                src="/Innovation in Every Bite.jpg"
                alt="Modern baking studio - place where Sarah creates innovative cupcake recipes"
                class="w-full h-64 object-cover rounded-2xl shadow-lg"
                loading="lazy"
                width={400}
                height={256}
              />
            </div>
            <div class="md:w-1/2">
              <h3 class="font-quicksand text-2xl font-bold text-gray-900 mb-4">Innovation in Every Bite</h3>
              <p class="font-nunito text-gray-600 leading-relaxed">
                Today I publish recipes and troubleshooting guides so home bakers can fix sunken centers, dry crumbs,
                and frosting issues. Incr-EdibleCupCakes is a recipe blog, not a retail bakery, focused on inclusive baking
                that still tastes like a treat.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* What you'll find */}
    <section class="py-20 bg-gradient-to-br from-cupcake-pink/20 to-sunshine-100/50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
          <h2 class="font-quicksand text-4xl font-black text-gray-900 mb-6">
            What You'll Find <span class="text-cupcake-coral">Here</span>
          </h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          {[
            { title: 'Tested Recipes', description: 'Every cupcake recipe is baked and revised at home before publishing.', color: 'bg-sunshine-400' },
            { title: 'Dietary Options', description: 'Classic, keto, vegan, nut-free, and gluten-free categories.', color: 'bg-sprinkle-blue' },
            { title: 'Troubleshooting Guides', description: 'Fix sinking centers, dryness, and frosting problems.', color: 'bg-sprinkle-green' },
            { title: 'Honest Notes', description: 'Clear ingredient lists, timing, and storage tips, no fake stats.', color: 'bg-cupcake-coral' },
          ].map((item, index) => (
            <div key={index} class="bg-white rounded-2xl p-6 shadow-lg text-center">
              <h3 class="font-quicksand text-xl font-bold text-gray-900 mb-2">{item.title}</h3>
              <p class="font-nunito text-gray-600">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Philosophy Section */}
    <section class="py-20 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="font-quicksand text-4xl font-black text-gray-900 mb-8">
          My Baking <span class="text-cupcake-coral">Philosophy</span>
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
          {[
            {
              title: 'Inclusivity',
              description: 'Every person deserves to enjoy incredible desserts, regardless of dietary needs.',
              icon: '🤝'
            },
            {
              title: 'Innovation',
              description: 'Traditional techniques meet modern nutritional science for extraordinary results.',
              icon: '💡'
            },
            {
              title: 'Quality',
              description: 'Only the finest ingredients and meticulous attention to detail in every recipe.',
              icon: '⭐'
            }
          ].map((principle, index) => (
            <div key={index} class="text-center">
              <div class="text-4xl mb-4">{principle.icon}</div>
              <h3 class="font-quicksand text-xl font-bold text-gray-900 mb-3">{principle.title}</h3>
              <p class="font-nunito text-gray-600">{principle.description}</p>
            </div>
          ))}
        </div>

        <blockquote class="font-nunito text-2xl font-medium text-gray-900 italic mb-8">
          "Baking is my way of spreading happiness, one cupcake at a time. Every recipe I create 
          is infused with love and the belief that extraordinary flavors should be accessible to everyone."
        </blockquote>
        
        <div class="flex justify-center space-x-6">
          <a
            href="https://instagram.com/incrediblecupcakes"
            class="font-quicksand flex items-center space-x-2 px-6 py-3 bg-gradient-to-r from-cupcake-coral to-sunshine-400 text-white rounded-full hover:from-cupcake-cherry hover:to-sunshine-500 transition-all duration-300 transform hover:scale-105 font-bold"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.174-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.402.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.357-.629-2.748-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24.009 12.017 24.009c6.624 0 11.99-5.367 11.99-11.988C24.007 5.367 18.641.001.012.001z"/>
            </svg>
            <span>Follow My Journey</span>
          </a>
          <a
            href="mailto:sarah@incr-ediblecupcakes.com"
            class="font-quicksand flex items-center space-x-2 px-6 py-3 border-2 border-cupcake-coral text-cupcake-coral rounded-full hover:bg-cupcake-coral hover:text-white transition-all duration-300 transform hover:scale-105 font-bold"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <span>Say Hello</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>