---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { validatedRecipes as recipes } from '../../data/recipes';
import {
  substitutesContent,
  getRelatedRecipesForSubstitute,
} from '../../data/substitutesContent';

export async function getStaticPaths() {
  return Object.keys(substitutesContent).map((ingredient) => ({
    params: { ingredient },
    props: { ingredient },
  }));
}

const { ingredient } = Astro.params;
const data = substitutesContent[ingredient || ''];
if (!data) {
  throw new Error(`Unknown substitute: ${ingredient}`);
}

const relatedRecipes = getRelatedRecipesForSubstitute(ingredient || '', recipes);
const canonicalUrl = `https://incr-ediblecupcakes.com/substitutes/${ingredient}`;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: data.faq.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

const howToSchema = {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: data.title,
  description: data.metaDescription,
  step: data.swaps.map((s, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: s.name,
    text: `${s.ratio}. Best for: ${s.bestFor}. ${s.note}`,
  })),
};
---

<BaseLayout
  title={`${data.title} | Incr-EdibleCupCakes`}
  description={data.metaDescription}
  canonical={canonicalUrl}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
  </Fragment>
  <Header />
  <main id="main-content" class="pt-24 lg:pt-28 pb-24">
    <div class="max-w-4xl mx-auto px-4">
      <Breadcrumbs
        items={[
          { name: 'Home', url: '/' },
          { name: 'Guides', url: '/guides' },
          { name: data.title },
        ]}
      />

      <article class="space-y-8">
        <header>
          <h1 class="text-4xl font-black text-gray-900 mb-4">{data.title}</h1>
          <p class="guide-summary text-lg text-rose-800 bg-rose-50 border border-rose-100 rounded-xl px-4 py-3">
            {data.intro}
          </p>
        </header>

        <section>
          <h2 class="text-2xl font-bold text-gray-900 mb-3">Why the substitute matters</h2>
          <p class="text-gray-700 leading-relaxed">{data.whyItMatters}</p>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Substitutes and ratios</h2>
          <div class="overflow-hidden rounded-xl border border-gray-200">
            <table class="w-full text-left text-sm">
              <thead>
                <tr class="bg-gray-50 border-b border-gray-200">
                  <th class="px-4 py-3 font-semibold text-gray-900">Swap</th>
                  <th class="px-4 py-3 font-semibold text-gray-900">Ratio</th>
                  <th class="px-4 py-3 font-semibold text-gray-900 hidden sm:table-cell">Best for</th>
                </tr>
              </thead>
              <tbody>
                {data.swaps.map((s) => (
                  <tr class="border-b border-gray-100 last:border-0">
                    <td class="px-4 py-3 font-medium text-gray-900 align-top">{s.name}</td>
                    <td class="px-4 py-3 text-gray-700 align-top">{s.ratio}</td>
                    <td class="px-4 py-3 text-gray-600 align-top hidden sm:table-cell">
                      {s.bestFor}
                      <span class="block text-xs text-gray-500 mt-1">{s.note}</span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        {data.deepDiveGuide && (
          <p class="text-gray-700">
            <a href={data.deepDiveGuide} class="text-rose-600 font-semibold hover:underline">
              {data.deepDiveLabel ?? 'Read the full guide →'}
            </a>
          </p>
        )}

        <section>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Common questions</h2>
          <div class="space-y-3">
            {data.faq.map((f) => (
              <details class="bg-white border border-gray-200 rounded-xl p-4">
                <summary class="font-semibold text-gray-900 cursor-pointer">{f.question}</summary>
                <p class="mt-2 text-gray-700 text-sm leading-relaxed">{f.answer}</p>
              </details>
            ))}
          </div>
        </section>

        <section>
          <h2 class="text-2xl font-bold text-gray-900 mb-4">Recipes that use this swap</h2>
          <ul class="list-disc pl-6 space-y-2">
            {relatedRecipes.map((r) => (
              <li>
                <a href={`/recipe/${r.slug}`} class="text-rose-600 hover:underline">{r.title}</a>
              </li>
            ))}
          </ul>
        </section>
      </article>
    </div>
  </main>
  <Footer />
</BaseLayout>
