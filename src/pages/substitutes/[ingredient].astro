---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { validatedRecipes as recipes } from '../../data/recipes';

const KNOWN = {
  egg: {
    title: 'Egg substitutes for cupcakes',
    intro: 'Popular egg replacements that actually work in cupcakes.',
    tips: ['Flax egg (1 tbsp ground flax + 3 tbsp water per egg)', 'Applesauce (1/4 cup per egg)', 'Commercial replacers (follow package)']
  },
  buttermilk: {
    title: 'Buttermilk substitutes for cupcakes',
    intro: 'When you run out of buttermilk, try these alternatives.',
    tips: ['Milk + 1 tbsp lemon juice or vinegar (per cup)', 'Yogurt + water/milk to thin', 'Kefir 1:1']
  },
  sugar: {
    title: 'Sugar substitutes for cupcakes',
    intro: 'Sweeteners and how they change texture and taste.',
    tips: ['Erythritol/monk fruit for keto (adjust cooling effect)', 'Coconut sugar (darker flavor)', 'Honey/maple (reduce other liquids)']
  },
  flour: {
    title: 'Flour substitutes for cupcakes',
    intro: 'Swapping all-purpose for gluten-free or alternatives.',
    tips: ['Use 1:1 GF blend with xanthan gum', 'Almond flour needs extra binders', 'Oat flour adds tenderness']
  }
};

export async function getStaticPaths() {
  return ['egg', 'buttermilk', 'sugar', 'flour'].map((ingredient) => ({ params: { ingredient }, props: { ingredient } }));
}

const { ingredient } = Astro.params;
const data = KNOWN[ingredient || ''] || { title: `Substitutes for ${ingredient}`, intro: 'Common swaps that work in cupcakes.', tips: [] };

const schemaData = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: data.title,
  description: data.intro,
  step: data.tips.map((t, i) => ({ "@type": "HowToStep", position: i + 1, name: t }))
};
---

<BaseLayout title={`${data.title} - Incr-EdibleCupCakes`} description={data.intro} canonical={`https://incr-ediblecupcakes.com/substitutes/${ingredient}`}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
  </Fragment>
  <Header />
  <main id="main-content" class="pt-16 lg:pt-20">
    <div class="max-w-4xl mx-auto px-4">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">{data.title}</h1>
      <p class="text-lg text-gray-700 mb-6">{data.intro}</p>
      <ul class="list-disc pl-6 space-y-2 mb-10">
        {data.tips.map((t) => (<li class="text-gray-700">{t}</li>))}
      </ul>
      <h2 class="text-2xl font-bold text-gray-900 mb-4">Related recipes</h2>
      <ul class="list-disc pl-6 space-y-2">
        {recipes.slice(0,6).map((r) => (<li><a href={`/recipe/${r.slug}`} class="text-rose-600 hover:underline">{r.title}</a></li>))}
      </ul>
    </div>
  </main>
  <Footer />
</BaseLayout>


