---
import { SITE_IMAGES, absoluteUrl } from '../data/siteAssets';

// Component to generate Open Graph images dynamically
export interface Props {
  title: string;
  description: string;
  image?: string;
}

const { title, description, image } = Astro.props;
const ogImage = image ? absoluteUrl(image) : absoluteUrl(SITE_IMAGES.hero);
---

<!-- Open Graph Image Meta Tags -->
<meta property="og:image" content={ogImage} />
<meta property="og:image:alt" content={`${title} - Incr-EdibleCupCakes Recipe`} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/png" />

<!-- Twitter Card Image Meta Tags -->
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={`${title} - Incr-EdibleCupCakes Recipe`} />
