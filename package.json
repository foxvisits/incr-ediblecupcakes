{
  "name": "incr-ediblecupcakes-astro",
  "type": "module",
  "version": "1.0.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node scripts/materialize-public-assets.mjs && cross-env NODE_OPTIONS=--max-old-space-size=4096 astro dev",
    "start": "node scripts/materialize-public-assets.mjs && cross-env NODE_OPTIONS=--max-old-space-size=4096 astro dev",
    "build": "node scripts/materialize-public-assets.mjs && cross-env NODE_OPTIONS=--max-old-space-size=4096 tsx scripts/update-seo.mjs --no-indexnow && cross-env NODE_OPTIONS=--max-old-space-size=4096 astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "astro check",
    "update-sitemap": "tsx scripts/update-sitemap.mjs",
    "update-seo": "tsx scripts/update-seo.mjs",
    "update-llms": "tsx scripts/update-llms.mjs",
    "indexnow": "tsx scripts/indexnow.mjs",
    "seo-check": "node scripts/seo-monitor.mjs",
    "content": "node scripts/content/cli.mjs",
    "content:run": "node scripts/content/cli.mjs run",
    "content:import": "node scripts/content/cli.mjs import",
    "content:status": "node scripts/content/cli.mjs status",
    "content:generate": "node scripts/content/cli.mjs generate",
    "content:approve": "node scripts/content/cli.mjs approve",
    "content:schedule": "node scripts/content/cli.mjs schedule",
    "content:cleanup": "node scripts/cleanup-generated-content.mjs",
    "content:publish-due": "node scripts/content/cli.mjs publish-due",
    "content:verify": "node scripts/content/cli.mjs verify"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/react": "^3.6.2",
    "@astrojs/sitemap": "^3.2.2",
    "@astrojs/tailwind": "^5.1.2",
    "@fal-ai/client": "^1.8.4",
    "astro": "^4.16.15",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "cross-env": "^7.0.3",
    "sharp": "^0.34.5",
    "tailwindcss-textshadow": "^2.1.3",
    "terser": "^5.48.0",
    "tsx": "^4.7.0"
  }
}
